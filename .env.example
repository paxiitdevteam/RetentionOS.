# Copy to ".env" in this folder (NEVER commit .env — it is gitignored).
# Backend loads this via dotenv when you run: npm run backend:dev
#
# NAS down? Use local MariaDB/MySQL + run: bash fix-database.sh (Git Bash as Administrator)

NODE_ENV=development
PORT=3000

DATABASE_URL=mysql://retentionos:YOUR_PASSWORD@localhost:3306/retentionos_dev
DB_HOST=localhost
DB_PORT=3306
DB_NAME=retentionos_dev
DB_USER=retentionos
DB_PASSWORD=YOUR_DATABASE_PASSWORD

REDIS_URL=redis://localhost:6379

JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

API_KEY_SECRET=YOUR_API_KEY_SECRET

STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

DASHBOARD_URL=http://localhost:3001
WIDGET_CDN_URL=http://localhost:3002
