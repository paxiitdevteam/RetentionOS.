{
  "name": "retentionos",
  "version": "1.0.0",
  "description": "RetentionOS - Universal SaaS Churn-Reduction Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "backend:dev": "cd . && npm --prefix . run backend:dev:internal",
    "backend:dev:internal": "ts-node-dev --respawn --transpile-only src-backend/server.ts",
    "backend:build": "cd . && npm --prefix . run backend:build:internal",
    "backend:build:internal": "tsc -p tsconfig-backend.json",
    "backend:start": "node dist-backend/server.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:start": "cd dashboard && npm start",
    "widget:build": "cd frontend/widget && npm run build",
    "db:migrate": "ts-node src-backend/db/migrate.ts",
    "db:seed": "ts-node src-backend/db/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "keywords": [
    "retention",
    "saas",
    "churn"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.11",
    "redis": "^5.10.0",
    "sequelize": "^6.37.7",
    "stripe": "^20.0.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
